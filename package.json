{
  "name": "nuxt-spec",
  "version": "0.2.0-alpha.7",
  "description": "Test-pack layer for Nuxt Applications",
  "repository": "github:AloisSeckar/nuxt-spec",
  "license": "MIT",
  "type": "module",
  "main": "./nuxt.config.ts",
  "scripts": {
    "analyze": "nuxt analyze",
    "eslint": "eslint .",
    "build": "pnpm test && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "prepublishOnly": "pnpm build",
    "preview": "nuxt preview",
    "start": "nuxt start",
    "test": "vitest run",
    "test-u": "vitest run -u",
    "test-i": "vitest"
  },
  "bin": {
    "nuxt-spec": "./bin/cli.js"
  },
  "exports": {
    ".": "./nuxt.config.ts",
    "./config": {
      "types": "./config/index.d.ts",
      "import": "./config/index.mjs",
      "default": "./config/index.mjs"
    },
    "./utils": {
      "types": "./utils/index.d.ts",
      "import": "./utils/index.ts",
      "default": "./utils/index.ts"
    }
  },
  "files": [
    "app",
    "bin",
    "config",
    "public",
    "utils"
  ],
  "dependencies": {
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "4.0.0",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitest/browser": "4.1.0",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/ui": "4.1.0",
    "@vue/test-utils": "2.4.6",
    "elrh-cosca": "0.3.5",
    "happy-dom": "20.8.4",
    "nuxt": "4.4.2",
    "pixelmatch": "7.1.0",
    "playwright-core": "1.58.2",
    "fast-png": "8.0.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "vitest-browser-vue": "2.1.0",
    "vue": "3.5.30",
    "vue-router": "5.0.3"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:vite@8.0.1",
      "minimatch": "^9.0.9",
      "tar": "^7.5.10",
      "h3@^1.0.0": "^1.15.8",
      "h3-next": "npm:h3@^2.0.1-rc.15",
      "serialize-javascript": "^7.0.3",
      "devalue": "^5.6.4"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
