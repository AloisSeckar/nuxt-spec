{
  "name": "nuxt-spec",
  "version": "0.2.3",
  "description": "Test-pack layer for Nuxt Applications",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AloisSeckar/nuxt-spec.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./nuxt.config.ts",
  "scripts": {
    "analyze": "nuxt analyze",
    "eslint": "eslint .",
    "build": "pnpm test && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "prepublishOnly": "pnpm build",
    "preview": "nuxt preview",
    "start": "nuxt start",
    "test": "vitest run",
    "test-u": "vitest run -u",
    "test-i": "vitest"
  },
  "bin": {
    "nuxt-spec": "bin/cli.js"
  },
  "exports": {
    ".": "./nuxt.config.ts",
    "./config": {
      "types": "./config/index.d.ts",
      "import": "./config/index.mjs",
      "default": "./config/index.mjs"
    },
    "./utils": {
      "types": "./utils/index.d.ts",
      "import": "./utils/index.ts",
      "default": "./utils/index.ts"
    },
    "./components": {
      "import": "./app/components/index.ts",
      "default": "./app/components/index.ts"
    }
  },
  "files": [
    "app",
    "bin",
    "config",
    "public",
    "utils",
    "nuxt.config.ts"
  ],
  "dependencies": {
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "4.0.3",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/browser": "4.1.8",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/ui": "4.1.8",
    "@vue/test-utils": "2.4.10",
    "elrh-cosca": "0.3.6",
    "fast-png": "8.0.0",
    "happy-dom": "20.9.0",
    "nuxt": "4.4.7",
    "pixelmatch": "7.2.0",
    "playwright-core": "1.60.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "vitest-browser-vue": "2.1.0",
    "vue": "3.5.35",
    "vue-router": "5.1.0"
  },
  "packageManager": "pnpm@11.5.0"
}
